# Beacon — environment variable template
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.

# ── Spotify ───────────────────────────────────────────────────────────────────
# OAuth app credentials from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Long-lived refresh token obtained via initial OAuth authorization flow
# To generate: run the OAuth helper script in scripts/spotify-auth.sh (Week 5)
SPOTIFY_REFRESH_TOKEN=

# ── Last.fm (optional) ────────────────────────────────────────────────────────
# Used as genre fallback when Spotify returns empty genres for an artist.
# Free API key at https://www.last.fm/api/account/create
LASTFM_API_KEY=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Email delivery (required — choose Resend or SendGrid) ─────────────────────
# Resend API key from https://resend.com (recommended)
RESEND_API_KEY=

# SendGrid API key from https://sendgrid.com (alternative to Resend)
SENDGRID_API_KEY=

# Recipient email address for briefings (your Gmail address)
DELIVERY_EMAIL_TO=

# ── Telegram delivery (optional) ──────────────────────────────────────────────
# Bot token from @BotFather (leave empty to skip Telegram delivery)
TELEGRAM_BOT_TOKEN=

# Your personal chat ID (run @userinfobot to find it)
TELEGRAM_CHAT_ID=

# ── App settings ──────────────────────────────────────────────────────────────
# IANA timezone string for cron scheduling (default: America/Merida)
TIMEZONE=America/Merida

# Log verbosity: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Set to true to print briefings to stdout without sending (default: false)
DRY_RUN=false
